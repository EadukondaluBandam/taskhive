generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  employee
}

model Company {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  projects  Project[]

  @@map("companies")
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  role             Role
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id])
  createdBy        String?
  creator          User?     @relation("UserCreator", fields: [createdBy], references: [id])
  users            User[]    @relation("UserCreator")
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  projects         Project[] @relation("UserProjects")

  @@index([companyId, role])
  @@index([createdBy])
  @@map("users")
}

model Project {
  id        String    @id @default(uuid())
  name      String
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  createdBy String
  creator   User      @relation("UserProjects", fields: [createdBy], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([createdBy])
  @@map("projects")
}
