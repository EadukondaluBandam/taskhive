NODE_ENV="production"
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/taskhive?sslmode=require"
FRONTEND_URL="https://your-site.pages.dev"
APP_BASE_URL="https://your-site.pages.dev"
CORS_ORIGIN="https://your-site.pages.dev"
JWT_SECRET="replace_with_strong_jwt_secret_at_least_32_chars"
REFRESH_SECRET="replace_with_strong_refresh_secret_at_least_32_chars"
COOKIE_SECRET="replace_with_strong_cookie_secret"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="youremail@gmail.com"
SMTP_PASS="your_app_password"
EMAIL_FROM="TaskHive <noreply@yourdomain.com>"
